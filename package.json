{
  "name": "skills-sentry-dev",
  "version": "1.0.0",
  "description": "Proxy service mapping pretty URLs to raw GitHub markdown for skills.sentry.dev",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts src/index.ts",
    "build": "tsc",
    "start": "node --import ./dist/instrument.js dist/index.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@sentry/hono": "^10.58.0",
    "@sentry/node": "^10.58.0",
    "hono": "^4.12.25"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
